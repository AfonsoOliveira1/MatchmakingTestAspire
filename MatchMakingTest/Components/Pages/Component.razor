@using MatchmakingTest.Data.Models

<input type="text"
       class="player-select"
       placeholder="ex: joao.silva"
       autocomplete="username"
       autofocus
       @bind="Username"
       @bind:event="oninput" />

@code {
    [Parameter] public string Username { get; set; } = "";
    [Parameter] public EventCallback<string> UsernameChanged { get; set; } //evento para atualizar sempre
}